{
  "name": "worship-presentation-assistant",
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "description": "Worship Presentation Assistant - Simple Worship Presentation App",
  "author": "IPCA",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\"",
    "test:split": "tsx src/renderer/hymnSplit.test.ts"
  },
  "dependencies": {
    "@gracious.tech/fetch-client": "^2.2.0",
    "bufferutil": "^4.1.0",
    "clsx": "^2.1.0",
    "electron-updater": "^6.1.7",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.363.0",
    "pptx-glimpse": "^0.10.4",
    "qrcode": "^1.5.1",
    "react": "^18.2.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "tailwind-merge": "^2.2.2",
    "utf-8-validate": "^6.0.6",
    "ws": "^8.13.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/ws": "^8.6.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.2",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "compression": "store",
    "copyright": "Copyright © Worship Presentation Assistant",
    "appId": "com.worship-presentation-assistant",
    "productName": "Worship Presentation Assistant",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/**/*",
      "!**/*.map",
      "!**/*.ts"
    ],
    "asarUnpack": [],
    "win": {
      "icon": "build/ico.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Worship Presentation Assistant",
      "artifactName": "Worship Presentation Assistant Setup.exe",
      "uninstallDisplayName": "Worship Presentation Assistant",
      "deleteAppDataOnUninstall": true
    }
  }
}
