# Auto detect text files and normalize line endings
* text=auto eol=lf
# Source files
*.ts     text
*.tsx    text
*.js     text
*.jsx    text
*.mjs    text
*.cjs    text
*.json   text
*.html   text
*.css    text
*.scss   text
*.sass   text
*.md     text
*.yml    text
*.yaml   text
# Shell scripts
*.sh     text eol=lf
# Windows scripts
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf
# Electron / Node native modules
*.node   binary
# Images
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
*.svg    text
# Fonts
*.ttf    binary
*.otf    binary
*.woff   binary
*.woff2  binary
# Archives
*.zip    binary
*.7z     binary
*.rar    binary
*.tar    binary
*.gz     binary
# Media
*.mp3    binary
*.wav    binary
*.ogg    binary
*.mp4    binary
*.webm   binary
# Electron build artifacts
*.exe filter=lfs diff=lfs merge=lfs -text
*.dll    binary
*.dmg    binary
*.app    binary
*.deb    binary
*.rpm    binary
*.AppImage binary
